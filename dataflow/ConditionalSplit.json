{
	"name": "ConditionalSplit",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_patients_df",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "SQL_DF",
						"type": "DatasetReference"
					},
					"name": "Male"
				},
				{
					"dataset": {
						"referenceName": "SQL_DF",
						"type": "DatasetReference"
					},
					"name": "Female"
				},
				{
					"dataset": {
						"referenceName": "SQL_DF",
						"type": "DatasetReference"
					},
					"name": "others"
				}
			],
			"transformations": [
				{
					"name": "split1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PatientID as string,",
				"          FirstName as string,",
				"          LastName as string,",
				"          MiddleName as string,",
				"          SSN as string,",
				"          PhoneNumber as string,",
				"          Gender as string,",
				"          DOB as date,",
				"          Address as string,",
				"          ModifiedDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 split(Gender == 'Male',",
				"     Gender == 'Female',",
				"     disjoint: false) ~> split1@(Male, Female, othet)",
				"split1@Male sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> Male",
				"split1@Female sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> Female",
				"split1@othet sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> others"
			]
		}
	}
}