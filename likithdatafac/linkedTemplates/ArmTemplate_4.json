					"sources": [
						{
							"dataset": {
								"referenceName": "DS_Providers",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "SQL_DF",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "aggregate1"
						},
						{
							"name": "window1"
						},
						{
							"name": "cast1"
						},
						{
							"name": "filter1"
