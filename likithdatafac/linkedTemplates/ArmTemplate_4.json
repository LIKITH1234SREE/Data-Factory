					],
					"scriptLines": [
						"source(output(",
						"          ProviderID as string,",
						"          FirstName as string,",
						"          LastName as string,",
						"          Specialization as string,",
						"          DeptID as string,",
						"          NPI as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 aggregate(groupBy(Specialization),",
						"     totalsales = sum(NPI)) ~> aggregate1",
						"aggregate1 window(over(Specialization),",
						"     desc(totalsales, true),",
						"     cumsum = sum(totalsales)) ~> window1",
						"window1 cast(output(",
						"          totalsales as string",
						"     ),",
						"     errors: true) ~> cast1",
						"cast1 filter(!isNull(totalsales)) ~> filter1",
						"filter1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
