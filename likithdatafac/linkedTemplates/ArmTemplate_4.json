							"dataset": {
								"referenceName": "DS_patients_df",
								"type": "DatasetReference"
							},
							"name": "Patients"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "SQL_DF",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "YearColumn"
						},
						{
							"name": "castDOB"
						},
						{
							"name": "ArrangingColumns"
						},
						{
							"name": "SortOnYear"
						}
					],
					"scriptLines": [
						"source(output(",
						"          PatientID as string,",
						"          FirstName as string,",
						"          LastName as string,",
						"          MiddleName as string,",
						"          SSN as string,",
						"          PhoneNumber as string,",
						"          Gender as string,",
						"          DOB as date,",
